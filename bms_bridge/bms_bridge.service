[Unit]
Description=JK BMS MQTT Bridge Daemon
After=network.target bluetooth.target mosquitto.service
Wants=network.target bluetooth.target mosquitto.service

[Service]
Type=simple
User=root
WorkingDirectory=/opt/jk-bms-mqtt
Environment="BMS_MAC=C8:47:80:22:29:9F"
Environment="MQTT_HOST=localhost"
ExecStart=/opt/jk-bms-mqtt/venv/bin/python main.py

Restart=always
RestartSec=10

StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target